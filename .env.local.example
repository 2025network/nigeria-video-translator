DATABASE_URL="file:./dev.db"
ADMIN_EMAIL="admin@sermonbridge.local"
ADMIN_PASSWORD="change-this-password"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
AUTH_COOKIE_SECURE="false"

# SMTP email delivery. Port 465 uses implicit TLS; port 587 uses STARTTLS.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_NAME="SermonBridge"
SMTP_FROM_EMAIL=""

# Server-side only. Leave empty for demo mode.
OPENAI_API_KEY=""
OPENAI_TRANSCRIPTION_MODEL="whisper-1"
# Optional override for recordings. Keep whisper-1 for segment timestamps and SRT output.
OPENAI_RECORDING_TRANSCRIPTION_MODEL="whisper-1"
OPENAI_TRANSLATION_MODEL="gpt-4o-mini"
OPENAI_LIVE_TRANSLATION_MODEL="gpt-4o-mini"
OPENAI_DIAGNOSTIC_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"

# Optional local FFmpeg override if ffmpeg-static cannot resolve on the server.
FFMPEG_PATH=""
