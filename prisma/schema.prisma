generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
  @@index([expiresAt, usedAt])
}

model Church {
  id                     String           @id @default(cuid())
  name                   String
  churchName             String
  slug                   String           @unique
  email                  String           @unique
  passwordHash           String
  plan                   String           @default("FULL_ACCESS")
  supportedLanguages     String           @default("Yoruba,Igbo,Hausa,Nigerian Pidgin")
  country                String
  city                   String           @default("")
  logoUrl                String?
  bannerUrl              String?
  description            String?
  pastorName             String?
  phone                  String?
  websiteUrl             String?
  facebookUrl            String?
  youtubeUrl             String?
  instagramUrl           String?
  address                String?
  youtubeLiveUrl         String
  defaultSpokenLanguage  String
  status                 String           @default("Active")
  languages              ChurchLanguage[]
  countries              ChurchCountry[]
  branches               ChurchBranch[]
  usageEvents            WidgetUsageEvent[]
  sermonSessions         SermonSession[]
  teamMembers            ChurchTeamMember[]
  authSessions           ChurchAuthSession[]
  teamActivities         ChurchTeamActivity[]
  sermonRecordings       SermonRecording[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model SermonSession {
  id                String    @id @default(cuid())
  churchId          String
  church            Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId          String?
  branch            ChurchBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  title             String
  sourceLanguage    String
  listenerLanguages String
  streamUrl         String?
  status            String    @default("READY")
  startedAt         DateTime?
  endedAt           DateTime?
  transcriptMessages SermonTranscriptMessage[]
  errorLogs         LiveSessionErrorLog[]
  listenerSessions  ListenerSession[]
  displayUsageEvents DisplayUsageEvent[]
  overlayUsageEvents OverlayUsageEvent[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([churchId, status, createdAt])
  @@index([branchId, status, createdAt])
  @@index([status, startedAt])
}

model OverlayUsageEvent {
  id           String        @id @default(cuid())
  sessionId    String
  session      SermonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType    String        @default("overlay_viewed")
  languageCode String
  cleanMode    Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([sessionId, eventType, createdAt])
  @@index([sessionId, languageCode])
  @@index([sessionId, cleanMode])
}

model DisplayUsageEvent {
  id           String        @id @default(cuid())
  sessionId    String
  session      SermonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType    String
  languageCode String
  kioskMode    Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([sessionId, eventType, createdAt])
  @@index([sessionId, languageCode])
  @@index([sessionId, kioskMode])
}

model ListenerSession {
  id           String        @id @default(cuid())
  sessionId    String
  session      SermonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  languageCode String
  country      String?
  userAgent    String?
  visitorId    String
  createdAt    DateTime      @default(now())

  @@index([sessionId, createdAt])
  @@index([sessionId, languageCode])
  @@index([visitorId, createdAt])
}

model SermonTranscriptMessage {
  id             String        @id @default(cuid())
  sessionId      String
  session        SermonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceText     String
  translatedText String
  language       String
  audioUrl       String?
  audioStatus    String?
  audioError     String?
  audioGeneratedAt DateTime?
  isApproved     Boolean       @default(true)
  createdAt      DateTime      @default(now())

  @@index([sessionId, language, createdAt])
}

model SermonRecording {
  id                  String                       @id @default(cuid())
  churchId            String
  church              Church                       @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId            String?
  branch              ChurchBranch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  title               String
  sourceLanguage      String
  targetLanguages     String
  fileUrl             String
  originalFileName    String
  status              String                       @default("UPLOADED")
  transcriptText      String?
  timedTranscriptJson String?
  errorMessage        String?
  translations        SermonRecordingTranslation[]
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([churchId, createdAt])
  @@index([churchId, status])
  @@index([branchId, createdAt])
}

model SermonRecordingTranslation {
  id             String          @id @default(cuid())
  recordingId    String
  recording      SermonRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  languageCode   String
  translatedText String
  subtitleUrl    String?
  status         String          @default("PROCESSING")
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([recordingId, languageCode])
  @@index([recordingId, status])
}

model LiveSessionErrorLog {
  id        String        @id @default(cuid())
  sessionId String
  session   SermonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message   String
  context   String?
  severity  String        @default("ERROR")
  createdAt DateTime      @default(now())

  @@index([sessionId, createdAt])
}

model ChurchBranch {
  id         String    @id @default(cuid())
  churchId   String
  church     Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  location   String
  pastorName String?
  email      String?
  phone      String?
  country    String    @default("")
  state      String    @default("")
  city       String    @default("")
  address    String    @default("")
  description String?
  bannerUrl  String?
  logoUrl    String?
  createdAt  DateTime  @default(now())
  disabledAt DateTime?
  usageEvents WidgetUsageEvent[]
  sermonSessions SermonSession[]
  teamMembers ChurchTeamMember[]
  teamActivities ChurchTeamActivity[]
  sermonRecordings SermonRecording[]

  @@unique([churchId, slug])
}

model ChurchTeamMember {
  id           String               @id @default(cuid())
  churchId     String
  church       Church               @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       ChurchBranch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name         String
  email        String               @unique
  passwordHash String
  role         String
  isActive     Boolean              @default(true)
  authSessions ChurchAuthSession[]
  activities   ChurchTeamActivity[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([churchId, isActive])
  @@index([churchId, role])
  @@index([branchId])
}

model ChurchAuthSession {
  id           String            @id @default(cuid())
  tokenHash    String            @unique
  churchId     String
  church       Church            @relation(fields: [churchId], references: [id], onDelete: Cascade)
  teamMemberId String?
  teamMember   ChurchTeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime          @default(now())

  @@index([churchId, expiresAt])
  @@index([teamMemberId, expiresAt])
}

model ChurchTeamActivity {
  id           String            @id @default(cuid())
  churchId     String
  church       Church            @relation(fields: [churchId], references: [id], onDelete: Cascade)
  teamMemberId String?
  teamMember   ChurchTeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  branchId     String?
  branch       ChurchBranch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  action       String
  metadata     String?
  createdAt    DateTime          @default(now())

  @@index([churchId, createdAt])
  @@index([teamMemberId, createdAt])
  @@index([branchId, createdAt])
}

model WidgetUsageEvent {
  id               String        @id @default(cuid())
  churchId         String?
  church           Church?       @relation(fields: [churchId], references: [id], onDelete: SetNull)
  branchId         String?
  branch           ChurchBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  churchSlug       String
  branchSlug       String?
  eventType        String
  selectedLanguage String?
  createdAt        DateTime      @default(now())

  @@index([churchSlug, eventType])
  @@index([branchSlug, eventType])
  @@index([churchId, eventType])
  @@index([branchId, eventType])
}

model ChurchOnboardingRequest {
  id          String   @id @default(cuid())
  churchName  String
  contactName String
  email       String
  phone       String
  country     String
  city        String
  websiteUrl  String   @default("")
  message     String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
}

model ChurchLanguage {
  id        String @id @default(cuid())
  language  String
  churchId  String
  church    Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([churchId, language])
}

model ChurchCountry {
  id       String @id @default(cuid())
  country  String
  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([churchId, country])
}
