generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
  @@index([expiresAt, usedAt])
}

model Church {
  id                     String           @id @default(cuid())
  name                   String
  churchName             String
  slug                   String           @unique
  email                  String           @unique
  passwordHash           String
  plan                   String           @default("FULL_ACCESS")
  supportedLanguages     String           @default("Yoruba,Igbo,Hausa,Nigerian Pidgin")
  country                String
  city                   String           @default("")
  logoUrl                String?
  bannerUrl              String?
  description            String?
  pastorName             String?
  phone                  String?
  websiteUrl             String?
  facebookUrl            String?
  youtubeUrl             String?
  instagramUrl           String?
  address                String?
  youtubeLiveUrl         String
  defaultSpokenLanguage  String
  status                 String           @default("Active")
  languages              ChurchLanguage[]
  countries              ChurchCountry[]
  branches               ChurchBranch[]
  usageEvents            WidgetUsageEvent[]
  sermonSessions         SermonSession[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model SermonSession {
  id                String    @id @default(cuid())
  churchId          String
  church            Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId          String?
  branch            ChurchBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  title             String
  sourceLanguage    String
  listenerLanguages String
  streamUrl         String?
  status            String    @default("READY")
  startedAt         DateTime?
  endedAt           DateTime?
  transcriptMessages SermonTranscriptMessage[]
  errorLogs         LiveSessionErrorLog[]
  listenerSessions  ListenerSession[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([churchId, status, createdAt])
  @@index([branchId, status, createdAt])
  @@index([status, startedAt])
}

model ListenerSession {
  id           String        @id @default(cuid())
  sessionId    String
  session      SermonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  languageCode String
  country      String?
  userAgent    String?
  visitorId    String
  createdAt    DateTime      @default(now())

  @@index([sessionId, createdAt])
  @@index([sessionId, languageCode])
  @@index([visitorId, createdAt])
}

model SermonTranscriptMessage {
  id             String        @id @default(cuid())
  sessionId      String
  session        SermonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceText     String
  translatedText String
  language       String
  audioUrl       String?
  audioStatus    String?
  audioError     String?
  createdAt      DateTime      @default(now())

  @@index([sessionId, language, createdAt])
}

model LiveSessionErrorLog {
  id        String        @id @default(cuid())
  sessionId String
  session   SermonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message   String
  context   String?
  createdAt DateTime      @default(now())

  @@index([sessionId, createdAt])
}

model ChurchBranch {
  id         String    @id @default(cuid())
  churchId   String
  church     Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  location   String
  pastorName String?
  email      String?
  phone      String?
  country    String    @default("")
  state      String    @default("")
  city       String    @default("")
  address    String    @default("")
  description String?
  bannerUrl  String?
  logoUrl    String?
  createdAt  DateTime  @default(now())
  disabledAt DateTime?
  usageEvents WidgetUsageEvent[]
  sermonSessions SermonSession[]

  @@unique([churchId, slug])
}

model WidgetUsageEvent {
  id               String        @id @default(cuid())
  churchId         String?
  church           Church?       @relation(fields: [churchId], references: [id], onDelete: SetNull)
  branchId         String?
  branch           ChurchBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  churchSlug       String
  branchSlug       String?
  eventType        String
  selectedLanguage String?
  createdAt        DateTime      @default(now())

  @@index([churchSlug, eventType])
  @@index([branchSlug, eventType])
  @@index([churchId, eventType])
  @@index([branchId, eventType])
}

model ChurchOnboardingRequest {
  id          String   @id @default(cuid())
  churchName  String
  contactName String
  email       String
  phone       String
  country     String
  city        String
  websiteUrl  String   @default("")
  message     String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
}

model ChurchLanguage {
  id        String @id @default(cuid())
  language  String
  churchId  String
  church    Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([churchId, language])
}

model ChurchCountry {
  id       String @id @default(cuid())
  country  String
  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([churchId, country])
}
